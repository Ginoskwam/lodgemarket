# Configuration pour les tests
# Copier ce fichier vers .env.test.local et remplir les valeurs

# Supabase Configuration (projet de test ou local)
NEXT_PUBLIC_SUPABASE_URL=http://localhost:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_test_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_test_service_role_key

# VAPID Keys pour les notifications push (optionnel en test)
NEXT_PUBLIC_VAPID_PUBLIC_KEY=your_test_vapid_public_key
VAPID_PRIVATE_KEY=your_test_vapid_private_key

# Email Service (optionnel - mocké dans les tests)
RESEND_API_KEY=your_test_resend_key
RESEND_FROM_EMAIL=test@tonmatos.test

# Environnement
NODE_ENV=test

